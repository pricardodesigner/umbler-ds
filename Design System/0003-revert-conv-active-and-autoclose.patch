@@ -1508,6 +1509,7 @@
       --umb-chat-bubble-out-bg:    #557CF2;
       --umb-chat-bubble-out-color: #ffffff;
       --umb-chat-list-hover:       rgba(0,0,0,.03);
+      --umb-chat-list-active:      rgba(85,124,242,.10);
       --umb-chat-sep-bg:           rgba(0,0,0,.06);
       --umb-chat-pinned-bg:        #FFF8DD;
       --umb-chat-pinned-color:     #8A6D00;
@@ -1524,6 +1526,7 @@
       --umb-chat-bubble-out-bg:    #29958D;
       --umb-chat-bubble-out-color: #ffffff;
       --umb-chat-list-hover:       rgba(0,0,0,.03);
+      --umb-chat-list-active:      rgba(41,149,141,.10);
       --umb-chat-sep-bg:           rgba(0,0,0,.06);
       --umb-chat-pinned-bg:        #FFF8DD;
       --umb-chat-pinned-color:     #8A6D00;
@@ -1540,6 +1543,7 @@
       --umb-chat-bubble-out-bg:    #2B897F;
       --umb-chat-bubble-out-color: #ffffff;
       --umb-chat-list-hover:       rgba(255,255,255,.04);
+      --umb-chat-list-active:      rgba(43,137,127,.16);
       --umb-chat-sep-bg:           rgba(255,255,255,.07);
       --umb-chat-pinned-bg:        rgba(255,214,10,.08);
       --umb-chat-pinned-color:     #e8d588;
@@ -1623,7 +1627,7 @@
     }
     .umb-conv-item:hover { background: var(--umb-chat-list-hover); }
     .umb-conv-item.active {
-      background: var(--umb-bg-active);
+      background: var(--umb-chat-list-active);
       box-shadow: inset 3px 0 0 var(--bs-primary);
     }
     .umb-conv-avatar {
@@ -5650,39 +5654,6 @@ const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
     } else {
       initComponentTooltips();
     }
-    // ════════════════════════════════════════════════════════════
-    // Auto-close do avatar-menu (§12 rules.md)
-    // Handlers defensivos: clique fora fecha o dropdown + ESC fecha.
-    // O Bootstrap dropdown já faz isso via data-api; estes handlers
-    // garantem o comportamento mesmo em contextos onde o auto-close
-    // padrão pode falhar (overflow:hidden em containers de preview,
-    // elementos criados dinamicamente via <template>, etc.).
-    // ════════════════════════════════════════════════════════════
-    function initAvatarMenuAutoClose() {
-      if (\!window.bootstrap) return;
-      document.addEventListener('click', function(e) {
-        document.querySelectorAll('.umb-avatar-menu .dropdown-menu.show').forEach(function(menu) {
-          var host = menu.closest('.umb-avatar-menu');
-          if (host && \!host.contains(e.target)) {
-            var trigger = host.querySelector('[data-bs-toggle="dropdown"]');
-            if (trigger) bootstrap.Dropdown.getOrCreateInstance(trigger).hide();
-          }
-        });
-      });
-      document.addEventListener('keydown', function(e) {
-        if (e.key \!== 'Escape') return;
-        document.querySelectorAll('.umb-avatar-menu .dropdown-menu.show').forEach(function(menu) {
-          var trigger = menu.closest('.umb-avatar-menu').querySelector('[data-bs-toggle="dropdown"]');
-          if (trigger) bootstrap.Dropdown.getOrCreateInstance(trigger).hide();
-        });
-      });
-    }
-    if (document.readyState === 'loading') {
-      document.addEventListener('DOMContentLoaded', initAvatarMenuAutoClose);
-    } else {
-      initAvatarMenuAutoClose();
-    }
-
     // Expor para possíveis re-renders manuais.
     window.umbRenderShell = function(){ renderSidebars(); renderHeaders(); renderMobileHeaders(); initComponentTooltips(); };
   })();
