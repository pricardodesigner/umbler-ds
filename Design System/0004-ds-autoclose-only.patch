Content-Transfer-Encoding: 8bit

Handler defensivo no IIFE principal do DS garante o contrato documentado
em §12 do rules.md (close-on-outside-click + ESC). Isso propaga o
comportamento para qualquer tela gerada com data-umb-c="sidebar",
não só o chat.html.

Patch cirúrgico: só adiciona o handler — nenhuma alteração de CSS,
nenhuma remoção de token.
---
 umbootstrap-design-system.html | 28 ++++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/umbootstrap-design-system.html b/umbootstrap-design-system.html
index 7167111..93a3b60 100644
--- a/umbootstrap-design-system.html
+++ b/umbootstrap-design-system.html
@@ -5654,6 +5654,34 @@ const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
     } else {
       initComponentTooltips();
     }
+    // Auto-close do avatar-menu (§12): clique fora e tecla Esc fecham o dropdown.
+    // Handler defensivo — se o data-api do Bootstrap falhar (elementos criados
+    // via <template>, containers com overflow:hidden), garantimos o comportamento.
+    function initAvatarMenuAutoClose() {
+      if (!window.bootstrap) return;
+      document.addEventListener('click', function(e) {
+        document.querySelectorAll('.umb-avatar-menu .dropdown-menu.show').forEach(function(menu) {
+          var host = menu.closest('.umb-avatar-menu');
+          if (host && !host.contains(e.target)) {
+            var trigger = host.querySelector('[data-bs-toggle="dropdown"]');
+            if (trigger) bootstrap.Dropdown.getOrCreateInstance(trigger).hide();
+          }
+        });
+      });
+      document.addEventListener('keydown', function(e) {
+        if (e.key !== 'Escape') return;
+        document.querySelectorAll('.umb-avatar-menu .dropdown-menu.show').forEach(function(menu) {
+          var trigger = menu.closest('.umb-avatar-menu').querySelector('[data-bs-toggle="dropdown"]');
+          if (trigger) bootstrap.Dropdown.getOrCreateInstance(trigger).hide();
+        });
+      });
+    }
+    if (document.readyState === 'loading') {
+      document.addEventListener('DOMContentLoaded', initAvatarMenuAutoClose);
+    } else {
+      initAvatarMenuAutoClose();
+    }
+
     // Expor para possíveis re-renders manuais.
     window.umbRenderShell = function(){ renderSidebars(); renderHeaders(); renderMobileHeaders(); initComponentTooltips(); };
   })();
