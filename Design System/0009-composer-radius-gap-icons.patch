-                          <button class="btn btn-icon btn-text" aria-label="Emoji" data-bs-toggle="tooltip" data-bs-placement="top" title="Emoji"><i class="ph ph-smiley"></i></button>
-                          <button class="btn btn-icon btn-text" aria-label="Templates" data-bs-toggle="tooltip" data-bs-placement="top" title="Templates"><i class="ph ph-chat-teardrop-text"></i></button>
-                          <button class="btn btn-icon btn-text" aria-label="Respostas rapidas" data-bs-toggle="tooltip" data-bs-placement="top" title="Respostas rapidas"><i class="ph ph-quotes"></i></button>
-                          <button class="btn btn-icon btn-text" aria-label="Variaveis" data-bs-toggle="tooltip" data-bs-placement="top" title="Variaveis"><i class="ph ph-brackets-curly"></i></button>
-                          <button class="btn btn-icon btn-text" aria-label="Stickers" data-bs-toggle="tooltip" data-bs-placement="top" title="Stickers"><i class="ph ph-sticker"></i></button>
-                          <button class="btn btn-icon btn-text" aria-label="Assinatura" data-bs-toggle="tooltip" data-bs-placement="top" title="Assinatura"><i class="ph ph-signature"></i></button>
+                          <button class="btn btn-icon btn-text" aria-label="Anexar arquivo" data-bs-toggle="tooltip" data-bs-placement="top" title="Anexar arquivo"><i class="ph ph-paperclip"></i></button>
+                          <button class="btn btn-icon btn-text" aria-label="Teclado emoji" data-bs-toggle="tooltip" data-bs-placement="top" title="Teclado emoji"><i class="ph ph-smiley"></i></button>
+                          <button class="btn btn-icon btn-text" aria-label="Respostas rapidas" data-bs-toggle="tooltip" data-bs-placement="top" title="Respostas rapidas"><i class="ph ph-chat-centered-dots"></i></button>
+                          <button class="btn btn-icon btn-text" aria-label="Templates" data-bs-toggle="tooltip" data-bs-placement="top" title="Templates"><i class="ph ph-quotes"></i></button>
