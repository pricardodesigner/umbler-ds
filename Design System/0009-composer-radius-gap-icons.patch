+                          <button class="btn btn-icon btn-text" aria-label="Editar atalhos" data-bs-toggle="tooltip" data-bs-placement="top" title="Editar atalhos"><i class="ph ph-pencil-simple"></i></button>
                         </div>
                         <div class="umb-chat-composer-toolbar-right">
                           <button class="btn btn-icon btn-text" aria-label="Agendar envio" data-bs-toggle="tooltip" data-bs-placement="top" title="Agendar envio"><i class="ph ph-clock"></i></button>
