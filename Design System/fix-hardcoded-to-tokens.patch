From 94a835065c61fc411d23552f35d56ef94e42c27c Mon Sep 17 00:00:00 2001
From: Paulo Ricardo <paulo@umbler.com>
Date: Tue, 21 Apr 2026 20:38:45 +0000
Subject: [PATCH] refactor(ds): elimina hardcoded em componentes, usa tokens
 existentes
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Auditoria do DS encontrou 14 valores hardcoded em componentes que
tinham token correspondente ja definido. Substituicoes (sem impacto
visual — valores sao identicos, so passam pela variavel):

TOOLTIP (.tooltip, .bs-tooltip-*, .umb-tooltip-demo — 10 subs):
- bg:    #080808 -> var(--umb-tooltip-bg)
- color: #f0f0f8 -> var(--umb-text-primary)

FORM VALIDATION (2 subs):
- .valid-feedback   color: #6dbba1 -> var(--umb-alert-success-color)
- .invalid-feedback color: #c4827d -> var(--umb-alert-danger-color)

HEALTH-DOT (4 subs + @keyframes):
- .hot  #22c55e -> var(--bs-success)
- .warm #f59e0b -> var(--bs-warning)
- .cold #ef4444 -> var(--bs-danger)

PRIMARY RGBA:
- .umb-choice-card:hover rgba(85,124,242,.04) ->
  rgba(var(--bs-primary-rgb), .04)

LEGITIMOS (mantidos sem alteracao):
- #fff/#000 em contraste sobre cor de marca
- Canais externos (§21.5): #25D366, #7c3aed, #ff6b35, #229ED9, etc.
- Gradientes decorativos de avatar IA
- Tokens de syntax highlighting (highlight.js)
- rgba inline em exemplos demo da pagina do proprio DS
---
 umbootstrap-design-system.html | 28 ++++++++++++++--------------
 1 file changed, 14 insertions(+), 14 deletions(-)

diff --git a/umbootstrap-design-system.html b/umbootstrap-design-system.html
index cd707c5..07eff66 100644
--- a/umbootstrap-design-system.html
+++ b/umbootstrap-design-system.html
@@ -687,8 +687,8 @@
 
     .form-control.is-valid   { border-color: var(--bs-success) !important; }
     .form-control.is-invalid { border-color: var(--bs-danger)  !important; }
-    .valid-feedback   { color: #6dbba1; font-size: 12px; }
-    .invalid-feedback { color: #c4827d; font-size: 12px; }
+    .valid-feedback   { color: var(--umb-alert-success-color); font-size: 12px; }
+    .invalid-feedback { color: var(--umb-alert-danger-color); font-size: 12px; }
 
     /* --- SWITCHES & CHECKS --- */
     .form-check-input { background-color: var(--umb-input-border); border-color: var(--umb-border-strong); cursor: pointer; }
@@ -856,7 +856,7 @@
 
     /* --- TOOLTIP --- */
     .umb-tooltip-demo { position: relative; display: inline-block; }
-    .umb-tooltip-demo .tooltip-box { display: none; position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%); background: #080808; color: #f0f0f8; border-radius: 6px; padding: 6px 10px; font-size: 12px; white-space: nowrap; box-shadow: 0 4px 12px rgba(0,0,0,.3); z-index: 99; }
+    .umb-tooltip-demo .tooltip-box { display: none; position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%); background: var(--umb-tooltip-bg); color: var(--umb-text-primary); border-radius: 6px; padding: 6px 10px; font-size: 12px; white-space: nowrap; box-shadow: 0 4px 12px rgba(0,0,0,.3); z-index: 99; }
     .umb-tooltip-demo:hover .tooltip-box { display: block; }
     /* Botão fechar — adapta ao tema */
     .btn-close { filter: none; }
@@ -866,13 +866,13 @@
       [data-bs-theme="auto"] .btn-close { filter: invert(1) grayscale(100%) brightness(200%); }
     }
     /* Bootstrap tooltip — força mesma cor em todos os temas */
-    .tooltip { --bs-tooltip-bg: #080808; --bs-tooltip-color: #f0f0f8; }
-    .tooltip .tooltip-inner { background-color: #080808; color: #f0f0f8; }
+    .tooltip { --bs-tooltip-bg: var(--umb-tooltip-bg); --bs-tooltip-color: var(--umb-text-primary); }
+    .tooltip .tooltip-inner { background-color: var(--umb-tooltip-bg); color: var(--umb-text-primary); }
     .tooltip .tooltip-arrow::before { border-color: transparent; }
-    .bs-tooltip-top    .tooltip-arrow::before { border-top-color:    #080808 !important; }
-    .bs-tooltip-bottom .tooltip-arrow::before { border-bottom-color: #080808 !important; }
-    .bs-tooltip-start  .tooltip-arrow::before { border-left-color:   #080808 !important; }
-    .bs-tooltip-end    .tooltip-arrow::before { border-right-color:  #080808 !important; }
+    .bs-tooltip-top    .tooltip-arrow::before { border-top-color:    var(--umb-tooltip-bg) !important; }
+    .bs-tooltip-bottom .tooltip-arrow::before { border-bottom-color: var(--umb-tooltip-bg) !important; }
+    .bs-tooltip-start  .tooltip-arrow::before { border-left-color:   var(--umb-tooltip-bg) !important; }
+    .bs-tooltip-end    .tooltip-arrow::before { border-right-color:  var(--umb-tooltip-bg) !important; }
 
     /* --- LOADER --- */
     .umb-loader { width: 36px; height: 36px; border: 3px solid rgba(var(--bs-primary-rgb),.2); border-top-color: var(--bs-primary); border-radius: 50%; animation: spin .8s linear infinite; }
@@ -882,10 +882,10 @@
 
     /* --- HEALTH DOTS --- */
     .health-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
-    .health-dot.hot  { background: #22c55e; box-shadow: 0 0 6px #22c55e; animation: pulse-hot 1.5s infinite; }
-    .health-dot.warm { background: #f59e0b; }
-    .health-dot.cold { background: #ef4444; }
-    @keyframes pulse-hot { 0%,100%{box-shadow:0 0 4px #22c55e} 50%{box-shadow:0 0 10px #22c55e} }
+    .health-dot.hot  { background: var(--bs-success); box-shadow: 0 0 6px var(--bs-success); animation: pulse-hot 1.5s infinite; }
+    .health-dot.warm { background: var(--bs-warning); }
+    .health-dot.cold { background: var(--bs-danger); }
+    @keyframes pulse-hot { 0%,100%{box-shadow:0 0 4px var(--bs-success)} 50%{box-shadow:0 0 10px var(--bs-success)} }
 
     /* --- MISC UTILS --- */
     .text-primary-umb { color: var(--umb-text-primary); }
@@ -1229,7 +1229,7 @@
       text-align: center; cursor: pointer; transition: all .2s;
       position: relative;
     }
-    .umb-choice-card:hover { border-color: var(--bs-primary); background: rgba(85,124,242,.04); }
+    .umb-choice-card:hover { border-color: var(--bs-primary); background: rgba(var(--bs-primary-rgb), .04); }
     .umb-choice-avatar {
       width: 64px; height: 64px; border-radius: 50%;
       background: var(--umb-hover-bg);
-- 
2.34.1

